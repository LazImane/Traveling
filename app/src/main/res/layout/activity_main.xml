<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bck"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Profile Button (anonymous → goes to Login) -->
        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_guest_avatar"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Profile" />

        <View
            android:layout_width="25dp"
            android:layout_height="0dp" />

        <!-- Logo -->
        <TextView
            android:layout_width="230dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:background="@drawable/traveling"
            android:contentDescription="Traveling logo" />

        <!-- Menu to add later -->

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:id="@+id/fragmentLayout">

    </FrameLayout>

    <!-- FOOTER NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Home" />

        <ImageButton
            android:id="@+id/navTravelPath"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_map"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Map" />

        <ImageButton
            android:id="@+id/navPost"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_post"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="New Post" />

        <ImageButton
            android:id="@+id/navGroups"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_groups"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Groups" />

        <ImageButton
            android:id="@+id/navNotifications"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_bell"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Notifications" />

    </LinearLayout>

</LinearLayout>